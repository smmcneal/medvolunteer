# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL used in invite/auth redirect links (production domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Protects /api/cron/* — also set the same value in Vercel project env vars
CRON_SECRET=generate-a-long-random-string

# Dev auto-login (/api/dev/login?role=admin|volunteer — dev only, 403 in prod)
DEV_ADMIN_EMAIL=admin@medvolunteer.org
DEV_ADMIN_PASSWORD=admin123
DEV_VOLUNTEER_EMAIL=alice@example.com
DEV_VOLUNTEER_PASSWORD=volunteer123

# Email (Resend)
RESEND_API_KEY=re_your_key
# Sender address — must be a verified domain in Resend for production
# Use onboarding@resend.dev for local dev (no domain verification needed, sends to your Resend account email only)
RESEND_FROM_EMAIL=noreply@envolv.org

# ── Notion automation ──────────────────────────────────────────────────────
# Integration secret from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your_notion_integration_token
# Dev Tasks & QA database ID — copy from the database URL:
#   https://notion.so/YOUR_WORKSPACE/[DATABASE_ID]?v=...
NOTION_DEV_TASKS_DB_ID=your_database_id_here

# ── Vercel webhook (for deployment → Notion sync) ─────────────────────────
# Signing secret generated when you create the webhook in Vercel dashboard:
#   Project → Settings → Webhooks → Add → copy "Signing Secret"
VERCEL_WEBHOOK_SECRET=your_vercel_webhook_signing_secret

# ── GitHub Actions secrets (set in GitHub, not .env.local) ───────────────
# These go in: GitHub repo → Settings → Secrets and variables → Actions
#   NOTION_TOKEN           (same value as above)
#   NOTION_DEV_TASKS_DB_ID (same value as above)
#   SUPABASE_ACCESS_TOKEN  — from https://app.supabase.com/account/tokens
#   SUPABASE_PROJECT_ID    — project ref from Supabase project settings URL
#   SUPABASE_DB_PASSWORD   — database password from Supabase project settings
