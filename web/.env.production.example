# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example
# Copy to .env.production (or set as Node.js App env vars in SiteGround cPanel)
# Never commit the real values — this file documents the shape only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys --json
# Public key also goes in Admin → Settings → Integrations → Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BOlBICFQ...your-public-key
VAPID_PRIVATE_KEY=4bKHZd...your-private-key
# Must be a mailto: or https: URI identifying the push sender
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Must be a verified domain in Resend (e.g. noreply@yourdomain.com)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── SMS (Twilio) — optional, only if SMS messaging is used ───────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# ── Background Checks (Checkr) — optional ────────────────────────────────────
# https://dashboard.checkr.com/account/settings/api_key
CHECKR_API_KEY=your_checkr_api_key

# ── E-Signatures (Dropbox Sign) — optional ───────────────────────────────────
# https://app.hellosign.com/api/reference
DROPBOX_SIGN_API_KEY=your_dropbox_sign_api_key

# ── Cron job protection ───────────────────────────────────────────────────────
# Any long random string; must match Authorization: Bearer <value> header
# Set this in Vercel → Project → Settings → Environment Variables too
CRON_SECRET=your-long-random-cron-secret

# ── Vercel webhook (deployment → Notion sync) ─────────────────────────────────
# Vercel → Project → Settings → Webhooks → signing secret
VERCEL_WEBHOOK_SECRET=your_vercel_webhook_signing_secret

# ── Notion automation (CI only — set as GitHub Actions secrets) ───────────────
# Integration secret from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your_notion_integration_token
# Dev Tasks & QA database ID from database URL
NOTION_DEV_TASKS_DB_ID=your_dev_tasks_database_id
# Feature Requests database ID (auto-build nightly CI)
NOTION_FEATURE_REQUESTS_DB_ID=your_feature_requests_database_id

# ── GitHub Actions secrets (set in repo → Settings → Secrets → Actions) ──────
# These are NEVER in .env files — set them directly in GitHub:
#   ANTHROPIC_API_KEY          Claude Code agent for auto-build CI
#   SUPABASE_ACCESS_TOKEN      https://app.supabase.com/account/tokens
#   SUPABASE_PROJECT_ID        Project ref from Supabase project settings URL
#   SUPABASE_DB_PASSWORD       Database password from Supabase project settings
#   GH_PAT                     GitHub Personal Access Token (repo + PR scopes)
#   NOTION_TOKEN               (same value as above)
#   NOTION_DEV_TASKS_DB_ID     (same value as above)
#   NOTION_FEATURE_REQUESTS_DB_ID (same value as above)

# ── Node.js ───────────────────────────────────────────────────────────────────
NODE_ENV=production
